<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NFC GO · Admin<% if (page === 'business' && business) { %> · <%= business.name %><% } %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="admin-body">

  <header class="admin-header">
    <a href="/admin" class="header-brand">
      <img
        src="https://nfcuniverse.online/wp-content/uploads/2026/03/logo-blanco-dentro-1.png"
        alt="NFC Universe"
        class="header-logo">
      <span class="header-title">NFC GO</span>
    </a>
    <nav class="admin-nav">
      <a href="/admin" class="nav-link<% if (page==='dashboard') { %> nav-link--active<% } %>">Negocios</a>
      <a href="/admin/logout" class="nav-link nav-link--logout">Salir</a>
    </nav>
  </header>

  <div class="admin-content">

    <!-- ── Flash toast ──────────────────────────────────────────────────────── -->
    <div id="admin-toast-anchor"></div>
    <% if (flash) { %>
      <div id="admin-toast" class="toast toast--<%= flash.type %>">
        <%= flash.type === 'success' ? '✓' : '✕' %> <%= flash.msg %>
      </div>
    <% } %>

    <!-- ── Panel de credenciales (solo al crear negocio con contraseña auto) ── -->
    <% if (newCredentials) { %>
    <section class="panel panel--creds">
      <h2 class="panel-title">⚠ Credenciales del panel de validación</h2>
      <p class="creds-notice">Anota estas credenciales ahora. La contraseña no se puede recuperar después.</p>
      <div class="creds-display">
        <div class="cred-row">
          <span class="cred-label">Usuario</span>
          <code class="cred-value"><%= newCredentials.username %></code>
        </div>
        <div class="cred-row">
          <span class="cred-label">Contraseña</span>
          <code class="cred-value cred-value--pass"><%= newCredentials.password %></code>
        </div>
        <div class="cred-row">
          <span class="cred-label">URL panel</span>
          <a href="/v/<%= newCredentials.username %>" target="_blank" class="cred-value">
            /v/<%= newCredentials.username %>
          </a>
        </div>
      </div>
    </section>
    <% } %>

  <% if (page === 'dashboard') { %>
  <!-- ═══════════════════════════════════════════════════════════════════════════
       DASHBOARD
  ══════════════════════════════════════════════════════════════════════════════ -->

    <!-- Stats globales -->
    <section class="stats-row">
      <div class="stat-card">
        <span class="stat-value"><%= stats.total %></span>
        <span class="stat-label">Total etiquetas</span>
      </div>
      <div class="stat-card stat-card--active">
        <span class="stat-value"><%= stats.active %></span>
        <span class="stat-label">Disponibles</span>
      </div>
      <div class="stat-card stat-card--claimed">
        <span class="stat-value"><%= stats.claimed %></span>
        <span class="stat-label">Reclamadas</span>
      </div>
      <div class="stat-card stat-card--disabled">
        <span class="stat-value"><%= stats.disabled %></span>
        <span class="stat-label">Canjeadas/Des.</span>
      </div>
    </section>

    <!-- Formulario nuevo negocio -->
    <section class="panel">
      <h2 class="panel-title">Nuevo negocio</h2>
      <form method="POST" action="/admin/businesses" class="form-grid">
        <div class="form-group">
          <label for="name">Nombre del negocio</label>
          <input type="text" id="name" name="name" placeholder="La Toscana" required>
        </div>
        <div class="form-group">
          <label for="slug">Slug (identificador único)</label>
          <input type="text" id="slug" name="slug" placeholder="la-toscana" required>
          <small>Solo letras, números y guiones. Se usará como prefijo.</small>
        </div>
        <div class="form-group">
          <label for="logo_url">URL del logo <span class="label-opt">(opcional)</span></label>
          <input type="url" id="logo_url" name="logo_url" placeholder="https://...">
        </div>
        <div class="form-group">
          <label for="reward_text">Texto de recompensa</label>
          <input type="text" id="reward_text" name="reward_text"
                 placeholder="10% de descuento en tu próxima visita" required>
        </div>
        <div class="form-group">
          <label for="validator_username">Usuario validador <span class="label-opt">(opcional)</span></label>
          <input type="text" id="validator_username" name="validator_username" placeholder="Se genera automáticamente">
          <small>Si se deja vacío, se usará el slug.</small>
        </div>
        <div class="form-group">
          <label for="validator_password">Contraseña validador <span class="label-opt">(opcional)</span></label>
          <input type="password" id="validator_password" name="validator_password" placeholder="Se genera automáticamente">
          <small>Si se deja vacía, se generará y mostrará al crear.</small>
        </div>
        <div class="form-group form-group--full">
          <button type="submit" class="btn btn--primary">Crear negocio</button>
        </div>
      </form>
    </section>

    <!-- Lista de negocios -->
    <section class="panel">
      <h2 class="panel-title">Negocios registrados</h2>
      <% if (businesses.length === 0) { %>
        <p class="empty-state">Aún no hay negocios. Crea el primero arriba.</p>
      <% } else { %>
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Nombre</th>
              <th>Slug</th>
              <th>Etiquetas</th>
              <th>Recompensa</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% businesses.forEach(b => { %>
            <tr>
              <td><strong><%= b.name %></strong></td>
              <td><code class="code-chip"><%= b.slug %></code></td>
              <td>
                <span class="tag-count">
                  <%= b.tag_count || 0 %>
                  <% if (b.claimed_count > 0) { %>
                    <span class="tag-count-claimed">(<%=b.claimed_count%> ✓)</span>
                  <% } %>
                </span>
              </td>
              <td class="td-reward"><%= b.reward_text %></td>
              <td>
                <span class="badge <%= b.active ? 'badge--active' : 'badge--disabled' %>">
                  <%= b.active ? 'Activo' : 'Inactivo' %>
                </span>
              </td>
              <td class="td-actions">
                <a href="/admin/businesses/<%= b.id %>" class="btn btn--sm btn--secondary">Ver etiquetas</a>
                <a href="/v/<%= b.slug %>" target="_blank" class="btn btn--sm" title="Panel de validación">Validación ↗</a>
                <button
                  class="btn btn--sm btn--danger"
                  data-business-id="<%= b.id %>"
                  data-business-name="<%= b.name %>"
                  onclick="deleteBusiness(this)">
                  Eliminar
                </button>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </section>

  <% } else if (page === 'business') { %>
  <!-- ═══════════════════════════════════════════════════════════════════════════
       DETALLE DE NEGOCIO
  ══════════════════════════════════════════════════════════════════════════════ -->

    <div class="page-header">
      <a href="/admin" class="back-link">← Volver</a>
      <h1 class="page-title"><%= business.name %></h1>
      <span class="badge <%= business.active ? 'badge--active' : 'badge--disabled' %>">
        <%= business.active ? 'Activo' : 'Inactivo' %>
      </span>
      <div class="page-header-actions">
        <a href="/v/<%= business.slug %>" target="_blank" class="btn btn--sm">Validación ↗</a>
        <a href="/admin/businesses/<%= business.id %>/export.csv"
           class="btn btn--sm">⬇ Exportar CSV</a>
        <form method="POST"
              action="/admin/businesses/<%= business.id %>/reset-all"
              onsubmit="return confirm('¿Resetear TODAS las etiquetas de este negocio a \"disponible\"?\n\nEsto borrará las fechas de reclamación y canje.')">
          <button type="submit" class="btn btn--sm btn--warn">↺ Resetear todas</button>
        </form>
      </div>
    </div>

    <!-- Stats del negocio -->
    <section class="stats-row">
      <div class="stat-card">
        <span class="stat-value"><%= stats.total %></span>
        <span class="stat-label">Total etiquetas</span>
      </div>
      <div class="stat-card stat-card--active">
        <span class="stat-value"><%= stats.active %></span>
        <span class="stat-label">Disponibles</span>
      </div>
      <div class="stat-card stat-card--claimed">
        <span class="stat-value"><%= stats.claimed %></span>
        <span class="stat-label">Reclamadas</span>
      </div>
      <div class="stat-card stat-card--disabled">
        <span class="stat-value"><%= stats.disabled %></span>
        <span class="stat-label">Canjeadas/Des.</span>
      </div>
    </section>

    <div class="two-col">

      <!-- Editar negocio -->
      <section class="panel">
        <h2 class="panel-title">Editar negocio</h2>
        <form method="POST" action="/admin/businesses/<%= business.id %>/edit" class="form-stack">
          <div class="form-group">
            <label>Nombre</label>
            <input type="text" name="name" value="<%= business.name %>" required>
          </div>
          <div class="form-group">
            <label>URL del logo</label>
            <input type="url" name="logo_url" value="<%= business.logo_url || '' %>">
          </div>
          <div class="form-group">
            <label>Texto de recompensa</label>
            <input type="text" name="reward_text" value="<%= business.reward_text %>" required>
          </div>
          <div class="form-group">
            <label>Estado</label>
            <select name="active">
              <option value="1" <%= business.active ? 'selected' : '' %>>Activo</option>
              <option value="0" <%= !business.active ? 'selected' : '' %>>Inactivo</option>
            </select>
          </div>
          <hr class="form-separator">
          <p class="form-section-label">Credenciales del panel de validación</p>
          <div class="form-group">
            <label>Usuario validador</label>
            <input type="text" name="validator_username" value="<%= business.validator_username || '' %>">
          </div>
          <div class="form-group">
            <label>Nueva contraseña <span class="label-opt">(dejar vacío para mantener)</span></label>
            <input type="password" name="validator_password" placeholder="••••••••">
          </div>
          <button type="submit" class="btn btn--primary">Guardar cambios</button>
        </form>
      </section>

      <!-- Generar etiquetas -->
      <section class="panel">
        <h2 class="panel-title">Generar etiquetas NFC</h2>
        <form method="POST" action="/admin/businesses/<%= business.id %>/generate" class="form-stack">
          <div class="form-group">
            <label>Prefijo del código (ej. TOSC)</label>
            <input type="text" name="prefix"
                   value="<%= business.slug.replace(/-/g,'').toUpperCase().substring(0,6) %>"
                   maxlength="8" required>
          </div>
          <div class="form-group">
            <label>Cantidad de etiquetas</label>
            <input type="number" name="count" value="30" min="1" max="200" required>
          </div>
          <div class="form-group">
            <label>Empezar numeración en</label>
            <input type="number" name="start_at" value="<%= (tags.length + 1) %>" min="1" required>
          </div>
          <button type="submit" class="btn btn--primary">Generar etiquetas</button>
        </form>
      </section>

    </div>

    <!-- ── Tabla de etiquetas ──────────────────────────────────────────────── -->
    <section class="panel">
      <div class="panel-header">
        <h2 class="panel-title">Etiquetas NFC (<%= tags.length %>)</h2>
        <% if (tags.length > 0) { %>
        <div class="panel-header-tools">
          <input
            type="text"
            id="tag-filter"
            class="filter-input"
            placeholder="🔍 Filtrar por código o estado…"
            autocomplete="off">
        </div>
        <% } %>
      </div>

      <!-- Bulk toolbar (hidden until checkboxes are selected) -->
      <% if (tags.length > 0) { %>
      <div id="bulk-toolbar" class="bulk-toolbar">
        <span class="bulk-info">
          <strong id="selected-count">0</strong> seleccionada(s)
        </span>
        <button id="btn-bulk-reset"  class="btn btn--sm btn--warn">↺ Resetear seleccionadas</button>
        <button id="btn-bulk-delete" class="btn btn--sm btn--danger">🗑 Eliminar seleccionadas</button>
      </div>
      <% } %>

      <% if (tags.length === 0) { %>
        <p class="empty-state">No hay etiquetas generadas aún. Usa el formulario de arriba.</p>
      <% } else { %>
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th class="th-cb">
                <input type="checkbox" id="cb-select-all" class="cb" title="Seleccionar todo">
              </th>
              <th>Código descuento</th>
              <th>Estado</th>
              <th>Reclamado</th>
              <th>URL NFC</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% tags.forEach(tag => { %>
            <tr class="tag-row"
                data-search="<%= `${tag.discount_code} ${tag.tag_code} ${tag.status}`.toLowerCase() %>">
              <td class="td-cb">
                <input type="checkbox" class="tag-cb cb" value="<%= tag.id %>">
              </td>
              <td>
                <code class="code-chip code-chip--highlight"><%= tag.discount_code %></code>
              </td>
              <td>
                <% if (tag.status === 'active') { %>
                  <span class="badge badge--active">Disponible</span>
                <% } else if (tag.status === 'claimed') { %>
                  <span class="badge badge--claimed">Reclamada</span>
                <% } else if (tag.status === 'redeemed') { %>
                  <span class="badge badge--redeemed">Canjeada</span>
                <% } else { %>
                  <span class="badge badge--disabled">Desactivada</span>
                <% } %>
              </td>
              <td class="td-date">
                <%= tag.claimed_at ? new Date(tag.claimed_at).toLocaleString('es-ES') : '—' %>
              </td>
              <td class="td-url">
                <div class="url-cell">
                  <code class="code-chip code-chip--sm code-chip--url nfc-url-code"
                        data-tag="<%= tag.tag_code %>"
                        title="Cargando URL…">
                    /c/<%= tag.tag_code.substring(0,8) %>…
                  </code>
                  <button class="btn btn--xs btn-copy"
                          data-tag="<%= tag.tag_code %>"
                          onclick="copyUrl(this)"
                          title="Copiar URL completa">
                    Copiar
                  </button>
                </div>
              </td>
              <td class="td-actions">
                <% if (tag.status === 'active') { %>
                  <form method="POST" action="/admin/tags/<%= tag.id %>/disable" style="display:inline">
                    <button class="btn btn--sm btn--danger">Desactivar</button>
                  </form>
                <% } else if (tag.status === 'disabled') { %>
                  <form method="POST" action="/admin/tags/<%= tag.id %>/enable" style="display:inline">
                    <button class="btn btn--sm btn--secondary">Activar</button>
                  </form>
                <% } else { %>
                  <!-- claimed o redeemed -->
                  <form method="POST" action="/admin/tags/<%= tag.id %>/enable" style="display:inline"
                        onsubmit="return confirm('¿Resetear esta etiqueta a disponible?')">
                    <button class="btn btn--sm btn--warn">Resetear</button>
                  </form>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <p id="filter-empty" class="empty-state hidden">
        Ninguna etiqueta coincide con el filtro.
      </p>
      <% } %>
    </section>

  <% } %>
  </div><!-- /admin-content -->

  <!-- Datos de contexto para admin.js -->
  <% if (page === 'business' && business) { %>
  <div id="js-data" data-business-id="<%= business.id %>" data-base-url="<%= baseUrl %>"></div>
  <% } else { %>
  <div id="js-data" data-base-url="<%= baseUrl %>"></div>
  <% } %>

  <script src="/admin.js"></script>
  <script>
    (function fixNfcUrls() {
      const base = window.location.origin;
      document.querySelectorAll('.nfc-url-code').forEach(code => {
        const tag  = code.dataset.tag;
        const full = base + '/c/' + tag;
        code.textContent = full;
        code.title = full;
      });
      document.querySelectorAll('.btn-copy[data-tag]').forEach(btn => {
        btn.dataset.url = base + '/c/' + btn.dataset.tag;
      });
    })();

    function copyUrl(el) {
      const url = el.dataset.url;
      if (!url) return;
      const finish = (ok) => {
        const orig = el.textContent;
        el.textContent = ok ? '¡Copiado!' : 'Error';
        el.classList.toggle('btn--copied', ok);
        setTimeout(() => { el.textContent = orig; el.classList.remove('btn--copied'); }, 1500);
      };
      if (navigator.clipboard?.writeText) {
        navigator.clipboard.writeText(url).then(() => finish(true)).catch(() => finish(false));
      } else {
        try {
          const ta = Object.assign(document.createElement('textarea'), { value: url, style: 'position:fixed;opacity:0' });
          document.body.appendChild(ta); ta.focus(); ta.select();
          document.execCommand('copy'); ta.remove(); finish(true);
        } catch { finish(false); }
      }
    }
  </script>
</body>
</html>

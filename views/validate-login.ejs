<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NFC GO · Validación · <%= business.name %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <main class="login-page">
    <div class="card card--login">
      <div class="brand brand--large">NFC GO</div>

      <% if (business.logo_url) { %>
        <img src="<%= business.logo_url %>" alt="<%= business.name %>" class="business-logo business-logo--small">
      <% } %>

      <h2 class="login-title">
        Panel de validación<br>
        <strong style="color:var(--text)"><%= business.name %></strong>
      </h2>

      <% if (error) { %>
        <div class="alert alert--error"><%= error %></div>
      <% } %>

      <form method="POST" action="/v/<%= business.slug %>/login" class="login-form">
        <label for="username">Usuario</label>
        <input
          type="text"
          id="username"
          name="username"
          placeholder="<%= business.slug %>"
          autocomplete="username"
          autofocus
          required
        >
        <label for="password">Contraseña</label>
        <input
          type="password"
          id="password"
          name="password"
          placeholder="••••••••"
          autocomplete="current-password"
          required
        >
        <button type="submit" class="btn btn--primary" style="margin-top:0.25rem">Entrar</button>
      </form>
    </div>
  </main>

  <footer class="landing-footer">
    <span class="brand">NFC GO</span>
    <span class="brand-tagline">Panel de validación para negocios</span>
  </footer>
</body>
</html>

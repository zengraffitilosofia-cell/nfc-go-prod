<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NFC GO · Admin</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <main class="login-page">

    <div class="login-logo-header">
      <img
        src="https://nfcuniverse.online/wp-content/uploads/2026/03/logo-blanco-dentro-1.png"
        alt="NFC Universe"
        class="login-logo">
      <span class="login-brand-text">NFC GO</span>
    </div>

    <div class="card card--login">
      <h1 class="login-title">Panel de administración</h1>
      <p class="login-subtitle">Acceso restringido al equipo NFC Universe</p>

      <% if (error) { %>
        <div class="alert alert--error"><%= error %></div>
      <% } %>

      <form method="POST" action="/admin/login" class="login-form">
        <div>
          <label for="password">Contraseña</label>
          <input
            type="password"
            id="password"
            name="password"
            placeholder="••••••••"
            autofocus
            required>
        </div>
        <button type="submit" class="btn btn--primary" style="width:100%">Entrar</button>
      </form>

      <p class="login-footer-note">NFC Universe · Sistema de gestión NFC GO</p>
    </div>

  </main>
</body>
</html>
